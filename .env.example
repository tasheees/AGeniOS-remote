# Required — copy this to .env and fill in values

# PWA login password (shown in Telegram on bridge start)
REMOTE_PASSWORD=your_password_here

# Telegram bot for startup notification
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Antigravity CDP debug port (default 9222)
# Set this in AG's launch args: --remote-debugging-port=9222
AG_CDP_PORT=9222
